# Kalshi API key — get from kalshi.com/profile/api-keys
KALSHI_API_KEY=your_kalshi_api_key_here

# The Odds API — free tier at the-odds-api.com (500 req/month)
# Used for sportsbook consensus lines as your "true probability" anchor
ODDS_API_KEY=your_odds_api_key_here

# Your bankroll in dollars (used for Kelly bet sizing)
BANKROLL=1000
